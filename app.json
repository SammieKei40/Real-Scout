{
  "expo": {
    "name": "RealScout",
    "slug": "RealScout",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "realscout",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/logo.png",
      "bundleIdentifier": "com.sammie-kei.RealScout"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#ffffff"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.sammie_kei.RealScout"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/logo.png",
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a5192e43-40a0-4e32-97b3-d7fb4951a3ed"
      }
    }
  }
}
