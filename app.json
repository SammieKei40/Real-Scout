{
  "expo": {
    "name": "",
    "slug": "RealScout",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "scheme": "realscout",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/logo.png",
      "bundleIdentifier": "com.sammie-kei.RealScout"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/logo.png",
          "imageWidth": 200,
          "dark": {
            "backgroundColor": "#121212",
            "image": "./assets/logo.png"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
